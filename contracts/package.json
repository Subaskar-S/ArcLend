{
  "name": "@arclend/contracts",
  "version": "1.0.0",
  "description": "ArcLend DeFi Protocol — Smart Contracts (Diamond EIP-2535)",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "clean": "hardhat clean",
    "deploy:localhost": "hardhat run deploy/00_deploy_all.ts --network localhost",
    "deploy:sepolia": "hardhat run deploy/00_deploy_all.ts --network sepolia",
    "deploy:mainnet": "hardhat run deploy/00_deploy_all.ts --network mainnet",
    "typecheck": "tsc --noEmit"
